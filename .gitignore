# --- Data ---
# Track ONLY the labels (data/active/Annotations-RGB.gpkg) + the inbox README.
# All imagery (Planet EDU-licensed) and generated products stay out of git.
data/active/imagery/
data/active/coco/
data/active/_backups/
data/cold/
data/inbox/*
!data/inbox/README.md
imagery/
outputs/
cache/
*.zip
*.aux.xml

# Transient SQLite sidecars from an open GeoPackage (QGIS)
*.gpkg-shm
*.gpkg-wal

# --- Python ---
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Node / frontend build ---
node_modules/
dist/

# --- Model weights / checkpoints ---
*.pt
*.pth
*.onnx
weights/

# --- Editor / IDE ---
.vscode/
.idea/

# --- Claude Code (agent config) ---
# CLAUDE.md (repo root) and shared .claude/settings.json ARE tracked; per-user
# local settings are not. (Also covered by the global ignore on this machine,
# but pinned here so a fresh clone honours it too.)
.claude/settings.local.json

# --- Exploratory C++ inspection tool + concept/learning material ---
# (kept locally alongside the project, intentionally not committed)
tools/geoinspect/
concept/

# --- C/C++ build artifacts ---
build/
*.o
*.obj

# --- OS ---
.DS_Store
